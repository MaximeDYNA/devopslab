# -*- mode: ruby -*-
# vi: set ft=ruby :

Vagrant.configure("2") do |config|

  # ==================================================
  # Base Box
  # ==================================================
  # ARM64 Ubuntu box compatible with Apple Silicon

  config.vm.box = "bento/ubuntu-22.04"

  # ==================================================
  # VM Hostname
  # ==================================================

  config.vm.hostname = "k8s-worker-1"

  # ==================================================
  # Private Network
  # ==================================================
  # Private network for VM-to-VM communication

  config.vm.network "private_network", ip: "192.168.56.40"

  # -------------------------------------------------
  # Synced Folder
  # -------------------------------------------------
  # Shared DevOpsLab workspace

  config.vm.synced_folder "../../", "/workspace", create: true

  # ==================================================
  # VMware Provider Configuration
  # ==================================================

  config.vm.provider "vmware_desktop" do |vmware|

    vmware.vmx["memsize"]  = "4096"
    vmware.vmx["numvcpus"] = "2"

    vmware.gui = false

  end

  # -------------------------------------------------
  # SSH Configuration
  # -------------------------------------------------

  config.ssh.insert_key = false

  # -------------------------------------------------
  # Provisioning
  # -------------------------------------------------

  config.vm.provision "shell",
    path: "../shared/scripts/bootstrap/k8s-worker-bootstrap.sh",
    privileged: true

end